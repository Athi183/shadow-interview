# Responsibility: document local backend environment variables without storing real secrets.
# Copy this file to .env for local development and fill in only the keys you want to use.

# Provider selection:
# - auto: try OpenAI, then Groq, then local mock fallback
# - openai: use OpenAI only
# - groq: use Groq only
# - mock: use local deterministic demo responses only
AI_PROVIDER=auto

# Keep the app demoable when external provider quota is unavailable.
ENABLE_MOCK_FALLBACK=true

# OpenAI / GPT-5.6 configuration.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6

# Optional Groq fallback configuration.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1
